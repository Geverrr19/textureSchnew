        "model": {
          "type": "model",
          "model": "item/grimoire_fixinium"
        }
      },
      {
        "when": "grimoire_violet",
        "model": {
          "type": "model",
          "model": "item/grimoire_violet"
        }
      },
      {
        "when": "quest_cat_finished",
        "model": {
          "type": "model",
          "model": "item/quest_cat_finished"
        }
      }
    ]
  }
}