        }
      },
      {
        "when": "grimoire_basic",
        "model": {
          "type": "model",
          "model": "item/grimoire_basic"
        }
      },
            {
        "when": "grimoire_fer",
        "model": {
          "type": "model",
          "model": "item/grimoire_fer"
        }
      },
            {
        "when": "grimoire_or",
        "model": {
          "type": "model",
          "model": "item/grimoire_or"
        }
      },
      {
        "when": "Blue_Grimoire",
        "model": {
          "type": "model",
          "model": "item/blue_grimoire"
        }
      },
            {
        "when": "Time_Grimoire",
        "model": {
          "type": "model",
          "model": "item/time_grimoire"
        }
      },
      {
        "when": "grimoire_diamant",
        "model": {
          "type": "model",
