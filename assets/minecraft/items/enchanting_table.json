    },
    "cases": [
      {
        "when": "board",
        "model": {
          "type": "model",
          "model": "block/board"
        }
      },
      {
        "when": "altar",
        "model":  {
          "type": "model",
          "model": "block/altar"
        }
      },
            {
        "when": "portal",
        "model":  {
          "type": "model",
          "model": "block/portal"
        }
      },
      {
        "when": "runic_table",
        "model":  {
          "type": "model",
          "model": "block/runic_table"
        }
      }
    ]
  }
}