{
  "model": {
    "type": "select",
    "property": "custom_model_data",
    "fallback": {
      "type": "model",
      "model": "item/echo_shard"
    },
    "cases": [
      {
        "when": "legendary_time",
        "model": {
          "type": "model",
          "model": "item/legendary_time"
        }
      },
      {
        "when": "legendary_gravity",
        "model": {
          "type": "model",
          "model": "item/legendary_gravity"
        }
      }
    ]
  }
}